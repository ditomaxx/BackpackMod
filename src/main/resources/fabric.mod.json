{
  "schemaVersion": 1,
  "id": "backpackmod",
  "version": "${version}",
  "name": "Backpackmod",
  "description": "This Mod adds a fully functional Backpack using the Trinkets API",
  "authors": [
    "Ditomax"
  ],
  "contact": {
    "Github": "https://github.com/DitomaxHD",
    "Modrinth": "https://modrinth.com/user/ditomax"
  },
  "license": "CC0-1.0",
  "icon": "assets/backpackmod/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.ditomax.BackpackMod"
    ],
    "client": [
      "com.ditomax.BackpackModClient"
    ],
    "fabric-datagen": [
      "com.ditomax.BackpackModDataGenerator"
    ]
  },
  "mixins": [
    "backpackmod.mixins.json",
    {
      "config": "backpackmod.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*",
    "trinkets": ">=3.9.0"
  }
}